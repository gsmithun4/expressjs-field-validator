{
  "name": "expressjs-field-validator",
  "version": "4.0.6",
  "description": "A powerful, lightweight Express.js middleware for validating request fields (body, query, params, headers) with a fluent, chainable API. Zero dependencies, TypeScript support, and auto API docs generation.",
  "homepage": "https://gsmithun4.github.io/expressjs-field-validator",
  "repository": {
    "type": "git",
    "url": "https://github.com/gsmithun4/expressjs-field-validator.git"
  },
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "test": "jest",
    "minify:validator": "node-minify --compressor uglify-js --input './lib/validator/validator.js' --output './lib/validator/index.js'",
    "minify:check-service": "node-minify --compressor uglify-js --input './lib/checkService/checkService.js' --output './lib/checkService/index.js'",
    "minify:skip-service": "node-minify --compressor uglify-js --input './lib/skipService/skipService.js' --output './lib/skipService/index.js'",
    "minify:query-builder": "node-minify --compressor uglify-js --input './lib/queryBuilder/queryBuilder.js' --output './lib/queryBuilder/index.js'",
    "minify:response-doc": "node-minify --compressor uglify-js --input './lib/responseDoc/responseDoc.js' --output './lib/responseDoc/index.js'",
    "minify:docs-generator": "node-minify --compressor uglify-js --input './lib/docGenerator/docGenerator.js' --output './lib/docGenerator/index.js'",
    "minify:index": "node-minify --compressor uglify-js --input 'index.js' --output 'index.js'",
    "test:coverage": "jest --coverage",
    "test:coverage-html": "jest --coverage --config='{ \"coverageReporters\": [\"html\", \"lcov\"] }'",
    "minify": "npm run minify:validator && npm run minify:check-service && npm run minify:skip-service && npm run minify:query-builder && npm run minify:response-doc && npm run minify:docs-generator && npm run minify:index"
  },
  "keywords": [
    "express",
    "expressjs",
    "express-js",
    "middleware",
    "validation",
    "validator",
    "validate",
    "request-validation",
    "field-validation",
    "body-validation",
    "query-validation",
    "header-validation",
    "params-validation",
    "json-validation",
    "input-validation",
    "schema-validation",
    "api-validation",
    "request-body",
    "api-documentation",
    "api-docs",
    "swagger-alternative",
    "type-checking",
    "sanitization",
    "express-middleware",
    "rest-api",
    "nodejs"
  ],
  "author": "Midhun G S",
  "license": "MIT",
  "devDependencies": {
    "@node-minify/cli": "^10.4.0",
    "@node-minify/uglify-js": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-plugin-import": "^2.32.0",
    "jest": "^30.2.0"
  },
  "engines": {
    "node": "24.14.0",
    "npm": "11.11.0"
  }
}
